{
  "name": "azaloop",
  "version": "0.2.0",
  "description": "AzaLoop 0.2 — PRD-driven autonomous development loop (8 unified MCP tools)",
  "capabilities": ["mcp", "hooks", "skills"],
  "mcp": {
    "serverPath": "@azaloop/mcp-server",
    "tools": [
      "aza_session",
      "aza_prd",
      "aza_loop",
      "aza_spec",
      "aza_quality",
      "aza_finish",
      "aza_memory",
      "aza_meta"
    ]
  },
  "hooks": {
    "session-start": "CLAUDE.md",
    "post-tool": "update-resume"
  }
}
