{
  "name": "azaloop",
  "version": "0.1.1",
  "private": true,
  "description": "AzaLoop - PRD-driven autonomous development loop engine for AI coding assistants",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/coeasy/azaloop.git"
  },
  "bugs": {
    "url": "https://github.com/coeasy/azaloop/issues"
  },
  "homepage": "https://github.com/coeasy/azaloop#readme",
  "author": "AzaLoop Contributors",
  "scripts": {
    "build": "pnpm -r build",
    "build:shared": "pnpm --filter @azaloop/shared build",
    "build:core": "pnpm --filter @azaloop/core build",
    "build:mcp": "pnpm --filter @azaloop/mcp-server build",
    "build:cli": "pnpm --filter @azaloop/cli build",
    "build:portable": "pnpm build && npx tsx scripts/build-portable.ts",
    "typecheck": "pnpm -r typecheck",
    "lint": "node scripts/repository-lint.mjs",
    "test": "vitest run",
    "test:spine": "vitest run tests/unit/task-board-0-3.test.ts tests/unit/completion-gate.test.ts tests/unit/maker-markers-0-3-1.test.ts tests/unit/prd-depth-0-4.test.ts tests/unit/stage-tool-groups-spine.test.ts",
    "test:all": "vitest run",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "pack": "pnpm build:portable",
    "test:watch": "vitest",
    "clean": "pnpm -r clean",
    "format": "prettier --write \"packages/*/src/**/*.ts\"",
    "prepare": "pnpm build"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "keywords": [
    "azaloop",
    "mcp",
    "mcp-server",
    "ai",
    "coding-assistant",
    "autonomous-development",
    "prd-driven",
    "cursor",
    "claude-code",
    "opencode"
  ],
  "devDependencies": {
    "tsx": "^4.23.0",
    "vitest": "^4.1.10",
    "prettier": "^3.4.0"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
